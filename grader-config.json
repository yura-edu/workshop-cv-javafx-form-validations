{
  "schemaVersion": "1.0",
  "templateSlug": "cv-javafx-form-validations",
  "evaluationBlocks": [
    {
      "blockId": "auto",
      "evaluationType": "automated_pipeline",
      "weight": 70,
      "metrics": [
        {
          "metricKey": "test_coverage",
          "worker": "MetricsWorker",
          "weight": 40,
          "threshold": 0.85,
          "config": {
            "tool": "jacoco",
            "scope": "com/yura/workshop/validators",
            "coverageType": "LINE"
          }
        },
        {
          "metricKey": "lint_violations",
          "worker": "MetricsWorker",
          "weight": 35,
          "threshold": 0,
          "config": {
            "tool": "checkstyle",
            "configFile": "checkstyle.xml"
          }
        },
        {
          "metricKey": "cyclomatic_complexity",
          "worker": "MetricsWorker",
          "weight": 25,
          "threshold": 10,
          "config": {
            "tool": "checkstyle",
            "rule": "CyclomaticComplexity",
            "maxAllowed": 10
          }
        }
      ]
    },
    {
      "blockId": "teacher",
      "evaluationType": "teacher_review",
      "weight": 30,
      "checklist": [
        "El layout se adapta correctamente al redimensionar la ventana",
        "Los mensajes de error indican exactamente qué campo falló y por qué",
        "El diálogo de confirmación muestra un resumen con todos los datos del formulario"
      ]
    }
  ]
}
