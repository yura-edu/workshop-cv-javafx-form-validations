<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.yura.workshop.controllers.EmployeeFormController">

    <VBox spacing="16">
        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

        <Label text="Registro de Empleado"
               style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

        <!-- Nombre completo -->
        <VBox spacing="4">
            <Label text="Nombre completo *"/>
            <TextField fx:id="fullNameField" promptText="Ej: María García López"/>
            <Label fx:id="fullNameError" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;"/>
        </VBox>

        <!-- Email -->
        <VBox spacing="4">
            <Label text="Correo electrónico *"/>
            <TextField fx:id="emailField" promptText="ejemplo@empresa.com"/>
            <Label fx:id="emailError" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;"/>
        </VBox>

        <!-- Fecha de nacimiento -->
        <VBox spacing="4">
            <Label text="Fecha de nacimiento *"/>
            <DatePicker fx:id="birthDatePicker" promptText="dd/mm/yyyy"/>
            <Label fx:id="birthDateError" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;"/>
        </VBox>

        <!-- Departamento -->
        <VBox spacing="4">
            <Label text="Departamento *"/>
            <ComboBox fx:id="departmentCombo"
                      promptText="Selecciona un departamento"
                      maxWidth="Infinity"/>
            <Label fx:id="departmentError" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;"/>
        </VBox>

        <!-- Salario -->
        <VBox spacing="4">
            <Label text="Salario mensual (USD) *"/>
            <TextField fx:id="salaryField" promptText="Ej: 1500.00"/>
            <Label fx:id="salaryError" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;"/>
        </VBox>

        <!-- Foto de perfil -->
        <VBox spacing="4">
            <Label text="Foto de perfil * (.jpg, .jpeg, .png — máx 5 MB)"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button text="Elegir archivo" onAction="#onChoosePhoto"/>
                <Label fx:id="photoLabel" text="Ningún archivo seleccionado"
                       style="-fx-text-fill: #718096;"/>
            </HBox>
            <Label fx:id="photoError" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;"/>
        </VBox>

        <!-- Términos -->
        <CheckBox fx:id="termsCheckBox"
                  text="Acepto los términos y condiciones *"/>

        <!-- Submit -->
        <Button fx:id="submitButton"
                text="Registrar empleado"
                onAction="#onSubmit"
                maxWidth="Infinity"
                style="-fx-font-size: 14px; -fx-padding: 10 0;"/>

    </VBox>
</ScrollPane>
